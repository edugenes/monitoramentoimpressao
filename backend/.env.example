PORT=3001
DB_PATH=./database.db
TZ=America/Recife
SNMP_COLLECT_INTERVAL=*/5 * * * *

# JWT
JWT_SECRET=troque-em-producao
JWT_EXPIRES=24h

# Cota Local da impressora (EWS HP) - sincronizacao automatica de creditos
# Quando AUTO_SYNC_ENABLED=true e a impressora tem quota_sync_enabled=1, o sistema
# empurra os creditos restantes (limit + liberacoes - uso) para as contas Convidado
# e Outros via EWS. Quando os creditos zeram, a HP para de imprimir nessas contas.
EWS_USERNAME=admin
EWS_PASSWORD=
AUTO_SYNC_ENABLED=false
EWS_TLS_REJECT_UNAUTHORIZED=false
EWS_TIMEOUT_MS=8000
